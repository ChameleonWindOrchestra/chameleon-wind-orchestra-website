# MicroCMS connection (#23 / #24)
# Service domain is the prefix of `https://<domain>.microcms.io`.
# For this project: chameleon-wind-orchestra
MICROCMS_SERVICE_DOMAIN=chameleon-wind-orchestra

# API key issued from the MicroCMS admin console (Service settings → API keys).
# Use a key with read-only permissions on all 4 APIs (concerts / members / news / heroImages).
MICROCMS_API_KEY=
